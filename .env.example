# Aether Engine Environment Configuration
# Copy this file to .env and fill in your actual values

ENV=development
DEBUG=true

# Security
SECRET_KEY=
JWT_SECRET=

# Database / Redis
DATABASE_URL=
REDIS_URL=redis://localhost:6379/0

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# Storage
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=data
S3_BUCKET=
S3_REGION=eu-west-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Integrations (optional)
HUBSPOT_ENABLED=false
HUBSPOT_TOKEN=

VISION_API_URL=
VISION_API_KEY=
PRICING_MODEL_URL=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
APP_BASE_URL=

# Stripe price IDs — create these in the Stripe dashboard and paste the price_... IDs below.
STRIPE_PRICE_CORE=            # Inversiq Core — €399/month
STRIPE_PRICE_CORE_FOUNDING=   # Inversiq Core founding — €199/month
STRIPE_PRICE_GROWTH=          # Inversiq Growth — €899/month
STRIPE_PRICE_PRO=             # Inversiq Pro — €2499/month
STRIPE_PRICE_SCALE=           # Inversiq Scale — custom/manual (leave blank if handled outside Stripe)
STRIPE_PRICE_TOPUP=           # Top-up — €30 one-time for 10 extra requests

# Gmail outreach (API-based send; Workspace UI signature is not auto-applied)
GMAIL_SENDER_EMAIL=
OUTREACH_SIGNATURE_ENABLED=true
OUTREACH_SIGNATURE_SIGNOFF=Met vriendelijke groet,
OUTREACH_SIGNATURE_NAME=
OUTREACH_SIGNATURE_COMPANY=Inversiq
OUTREACH_SIGNATURE_WEBSITE=
OUTREACH_SIGNATURE_PHONE=