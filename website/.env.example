# ── Resend (e-mail) ────────────────────────────────────────────────────────────
# Haal op via resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Ontvanger van formulierinzendingen
# Wijzig naar info@inversiq.com wanneer live
CONTACT_TO_EMAIL=info@inversiq.com

# Afzenderadres (moet een verified domain zijn in Resend)
# Gebruik onboarding@resend.dev voor testen zonder eigen domein
CONTACT_FROM_EMAIL=onboarding@resend.dev

# ── Supabase (database) ────────────────────────────────────────────────────────
# Haal op via: Supabase dashboard → Settings → API

# Publieke project-URL (veilig om te exposen)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Service role key — uitsluitend server-side, NOOIT in client components
# Supabase dashboard → Settings → API → service_role (klik "Reveal")
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Admin ──────────────────────────────────────────────────────────────────────
# Wachtwoord voor /admin/scans
# Kies een sterk wachtwoord (minimaal 16 tekens aanbevolen)
ADMIN_SECRET=kies-een-sterk-wachtwoord
